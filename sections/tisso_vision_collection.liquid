{%- if section.settings.collection.products.size > 0 -%}
    <div class="product_grid_wrapper">
        <div class="page-width container">
            {% paginate section.settings.collection.products by section.settings.products_to_show %}
                {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
                    <div class="tissio_products">
                        <div class="product_image">
                            {%- if product.featured_media -%}
                                <img src="{{ product.featured_media | image_url:  width: 360, height: 360  }} 360w" width="" />
                            {% endif %}
                        </div>
                        <div class="product_text">
                            {{ product.title }}
                        </div>
                    </div>
                {% endfor %}
            {% endpaginate %}
        </div>
    </div>
{%- else -%}

{%- endif -%}


<style>
.product_grid_wrapper {
margin-top:20px;
}
.product_grid_wrapper > .container {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: flex-start;
}
.product_grid_wrapper > .container > * {
    flex: 0 0 100%;
    max-width: 32%;
}
.product_grid_wrapper > .container .product_image {
    overflow:hidden;
    display: inline-flex;
}
.product_grid_wrapper > .container .product_image img {
    max-width:100%;
    transition : 0.3s;
}
.product_grid_wrapper > .container .product_image img:hover {
    max-width:100%;
    transform: scale(1.05);
}
.product_grid_wrapper > .container .product_text {
margin-bottom:20px;}
</style>

{% schema %}
{
    "name": "Tisso Vision Collection",
    "tag": "section",
    "class": "section",
    "disabled_on": {
        "groups": ["header", "footer"]
    },
    "settings": [
         {
            "type": "text",
            "id": "heading",
            "label": "Heading"
        },
        {
            "type": "collection",
            "id": "collection",
            "label": "Collection"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "min": 2,
            "max": 25,
            "step": 1,
            "default": 6,
            "label": "Product to Show"
        },     
    ],
    "presets": [
        {
            "name": "Tisso Vision Collection",
            "category": "EcomExperts",
        }   
    ]
}
{%- endschema -%}