{%- if section.settings.collection.products.size > 0 -%}
    <div class="product_grid_wrapper">
        {% paginate section.settings.collection.products by section.settings.products_to_show %}
            {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
                <div class="tissio_products">
                    <div class="product_image">
                        {%- if product.featured_media -%}
                            <img src={{ product.featured_media | image_url }}  >
                        {% endif %}
                    </div>
                    <div class="product_text">
                        {{ product.title }}
                    </div>
                </div>
            {% endfor %}
        {% endpaginate %}
    </div>
{%- else -%}

{%- endif -%}

{% schema %}
{
    "name": "Tisso Vision Collection",
    "tag": "section",
    "class": "section",
    "disabled_on": {
        "groups": ["header", "footer"]
    },
    "settings": [
        {
            "type": "collection",
            "id": "collection",
            "label": "Collection"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "min": 2,
            "max": 25,
            "step": 1,
            "default": 6,
            "label": "Product to Show"
        },     
    ],
    "presets": [
        {
            "name": "Tisso Vision Collection",
            "category": "EcomExperts",
        }   
    ]
}
{%- endschema -%}