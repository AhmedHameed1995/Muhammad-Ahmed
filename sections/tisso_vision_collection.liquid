<div class="product_grid_wrapper">
    <div class="page-width container">
        <h2>{{section.settings.heading}}</h2>
    </div>
    <div class="page-width container">
        {%- for block in section.blocks -%}
            {%- assign product = all_products[block.settings.product] -%}
            {%- if product != blank -%}
                <div class="tissio_products" 
                    data-coordinates="{{ block.settings.coordinates | escape }}">
                    <div class="product_image">
                        {%- if product.featured_media -%}
                            <img 
                                src="{{ product.featured_media | image_url: width: 360, height: 360 }}" 
                                alt="{{ product.featured_media.alt | escape }}"
                                width="360" 
                                height="360"
                                loading="lazy"
                            >
                        {%- endif -%}
                        <span class="plus-icon" data-product-handle="{{ product.handle }}" style="top:{{ block.settings.coordinate_top | escape}}px; left:{{ block.settings.coordinate_left | escape }}px;">+</span>
                    </div>
                </div>
            {%- endif -%}
        {%- endfor -%}
        <!-- ===== Quick Add Modal (HTML) ===== -->
        <div id="quick-add-modal" class="qa-modal" aria-hidden="true">
            <div class="qa-backdrop" data-close-modal></div>
            <div class="qa-dialog" role="dialog" aria-modal="true" aria-labelledby="qa-modal-title">
                <button class="qa-close" type="button" aria-label="Close" data-close-modal>&times;</button>
                <div class="qa-body">
                    <div class="product_modal_wrap"> 
                        <div class="qa-media">
                            <img id="qa-image" alt="" />
                        </div>
                        <div class="qa-info">
                            <h3 id="qa-modal-title"></h3>
                            <div id="qa-modal-description"></div>   
                            <div class="qa-price" id="qa-price"></div>
                        </div>
                    </div>
                    <div class="product_modal_wrap"> 
                        <div class="qa-info">
                            <div class="qa-options"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>


<style>
.product_grid_wrapper {
    margin-top:20px;
}
.product_grid_wrapper > .container {
    display: flex;
    gap: 10px 15px;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: flex-start;
}
.product_grid_wrapper > .container > * {
    flex: 0 0 100%;
    max-width: 32%;
}
.product_grid_wrapper > .container .product_image {
    overflow:hidden;
    display: inline-flex;
    position:relative;
}
.product_grid_wrapper > .container .tissio_products:hover {
   cursor:pointer;
}

.product_grid_wrapper > .container .product_image img {
    max-width: 100%;
    height: 325px;
    object-fit:cover;
}
.product_grid_wrapper > .container .product_text a {
    text-decoration:none;
    color:currentColor;
}
.product_grid_wrapper > .container .product_text a:hover {
    text-decoration:underline;
}
.plus-icon {
    position: absolute;
    z-index: 5;
    background: #fff;
    font-size: 25px;
    width: 25px;
    height: 25px;
    line-height: 25px;
    text-align: center;
    color: #000;
    border-radius: 50%;
}

.qa-modal { position: fixed; inset: 0; display: none; z-index: 9999; max-width:100% !important; }
.qa-modal.is-open { display: block; }
.qa-backdrop { 
    position: absolute; 
    inset: 0; 
    background: rgba(0,0,0,.5);
    width: 100%;
    height: 100%;
    display: flex !important; 
}
.product_modal_wrap {
    display: grid; 
    grid-template-columns: 1fr 1fr; 
    gap: 20px;
}
.qa-dialog {
    position: relative;
    max-width: 500px;
    background: #fff;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, .2);
    top: 50%;
    transform: translateY(-50%);
    margin: 0 auto;
}
.qa-close {
  position: absolute; right: 10px; top: 10px; background: #fff; border: 1px solid #eee;
  width: 36px; height: 36px; border-radius: 999px; cursor: pointer; font-size: 20px; line-height: 1;
}
.qa-body { display:flex; flex-wrap:wrap; padding: 20px; }
.qa-media img { width: 100%; height: 225px; object-fit: cover; }
.qa-info h3 { margin: 0 0 8px; font-size: 20px; }
.qa-price { font-weight: 700; margin-bottom: 12px; }
.qa-price .compare { text-decoration: line-through; opacity: .6; margin-left: 8px; font-weight: 400; }
.qa-variant-wrap { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
.qa-variant-wrap select { padding: 10px; border: 1px solid #ddd; border-radius: 8px; }
.qa-actions { display: flex; gap: 10px; align-items: center; }
.qa-view-link { display: inline-block; padding: 10px 14px; border-radius: 8px; border: 1px solid #111; text-decoration: none; color: #111; font-weight: 600; }
@media (max-width: 768px) {
  .qa-body { grid-template-columns: 1fr; }
  .qa-media img { height: 300px; }
}
</style>
<script>

(function() {
  const modal = document.getElementById('quick-add-modal');
  const imgEl = document.getElementById('qa-image');
  const titleEl = document.getElementById('qa-modal-title');
  const descriptionEl = document.getElementById('qa-modal-description');
  const priceEl = document.getElementById('qa-price');
  const variantSelect = document.getElementById('qa-variant');
  const viewLink = document.getElementById('qa-view-link');

  // helpers
  function openModal() {
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    // prevent body scroll
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
    // focus close for accessibility
    modal.querySelector('.qa-close').focus();
  }
  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.documentElement.style.overflow = '';
    document.body.style.overflow = '';
  }
  function addWidthParam(url, width) {
    if (!url) return '';
    try {
      const u = new URL(url);
      if (!u.searchParams.get('width')) u.searchParams.set('width', String(width));
      return u.toString();
    } catch(_) {
      // fallback if relative URL
      const joiner = url.includes('?') ? '&' : '?';
      return url + joiner + 'width=' + width;
    }
  }
  function toCents(val) {
    const s = String(val ?? '');
    const n = Number(s.replace(/[^\d.]/g, ''));
    if (!isFinite(n)) return 0;
    return s.includes('.') ? Math.round(n * 100) : Math.round(n);
  }
  function formatMoneyGeneric(cents) {
    const currency = (window.Shopify && Shopify.currency && Shopify.currency.active) || 'USD';
    const locale = (window.Shopify && Shopify.locale) || navigator.language || 'en-US';
    return new Intl.NumberFormat(locale, { style: 'currency', currency }).format(cents / 100);
  }
  function formatMoney(value) {
    const cents = toCents(value);
    if (window.Shopify && typeof Shopify.formatMoney === 'function') {
      // Using Shopify's own formatter if available
      return Shopify.formatMoney(cents);
    }
    return formatMoneyGeneric(cents);
  }

  function renderPriceForVariant(variant, product) {
    const priceHTML = [];
    if (variant) {
      priceHTML.push(`<span class="price">${formatMoney(variant.price)}</span>`);
      // Some themes have compare_at_price for variants; fallback to product-level if needed
      const compare = variant.compare_at_price || product?.compare_at_price;
      if (compare && toCents(compare) > toCents(variant.price)) {
        priceHTML.push(`<span class="compare">${formatMoney(compare)}</span>`);
      }
    }
    priceEl.innerHTML = priceHTML.join('');
  }

  function populateModal(product) {
    titleEl.textContent = product.title || '';
    descriptionEl.innerHTML = product.description || '';
    viewLink.href = `/products/${product.handle}`;

    // image
    const firstImg =
      (product.images && product.images[0] && (product.images[0].src || product.images[0])) ||
      product.featured_image ||
      product.image;
    imgEl.src = firstImg ? addWidthParam(firstImg, 900) : '';
    imgEl.alt = product.title || '';

    // variants
    variantSelect.innerHTML = '';
    const variants = product.variants || [];
    console.log(product.variants);
    variants.forEach(v => {
      const opt = document.createElement('option');
      opt.value = v.id;
      opt.textContent = v.title + (v.available === false ? ' — Sold out' : '');
      opt.dataset.price = v.price;
      opt.dataset.compare = v.compare_at_price || '';
      variantSelect.appendChild(opt);
    });

    const defaultVariant =
      variants.find(v => v.available) || variants[0] || null;
    if (defaultVariant) {
      variantSelect.value = String(defaultVariant.id);
    }

    renderPriceForVariant(defaultVariant, product);
    openModal();
  }

  /* ==== build Color/Size UI into .qa-options (vanilla JS) ==== */
    function renderOptionsUI(product) {
    const variants = product.variants || [];
    const qaInfo = document.querySelector('.qa-info');
    let optWrap = document.querySelector('.qa-options');
    if (!optWrap) {
        optWrap = document.createElement('div');
        optWrap.className = 'qa-options';
        qaInfo.appendChild(optWrap);
    }
    optWrap.innerHTML = '';

    // --- gather option names + values from variants ---
    const optionNames = Array.isArray(product.options) ? product.options : [];
    const options = [1,2,3].map(i => ({
        index: i,
        name: optionNames[i-1] || `Option ${i}`,
        values: Array.from(new Set(variants.map(v => v[`option${i}`]).filter(Boolean)))
    })).filter(o => o.values.length);

    const colorOpt = options.find(o => /color/i.test(o.name));
    const sizeOpt  = options.find(o => /size/i.test(o.name));

    // helpers
    function slug(s){ return String(s).toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/(^-|-$)/g,''); }
    function colorToHex(name) {
        const map = {black:'#000', white:'#fff', blue:'#1E3A8A', navy:'#001F54', green:'#22C55E', red:'#DC2626',
        pink:'#EC4899', yellow:'#F59E0B', purple:'#7C3AED', grey:'#6B7280', gray:'#6B7280',
        beige:'#F5F5DC', brown:'#8B4513', orange:'#F97316', silver:'#C0C0C0', gold:'#D4AF37'};
        const n = String(name||'').toLowerCase();
        const hex = n.match(/#([0-9a-f]{3,8})/i); if (hex) return hex[0];
        if (/^rgb/.test(n)) return n;
        const base = Object.keys(map).find(k => n.includes(k));
        return base ? map[base] : '#111';
    }
    function anyAvailable(filter) {
        return variants.some(v => Object.keys(filter).every(k => v[k] === filter[k]) && v.available);
    }
    function getSelection() {
        const sel = {};
        if (colorOpt) {
        if (colorOpt.values.length <= 3) {
            const checked = optWrap.querySelector('input[name="qa-color"]:checked');
            sel[`option${colorOpt.index}`] = checked ? checked.value : '';
        } else {
            sel[`option${colorOpt.index}`] = optWrap.querySelector('#qa-color')?.value || '';
        }
        }
        if (sizeOpt) {
        sel[`option${sizeOpt.index}`] = optWrap.querySelector('#qa-size')?.value || '';
        }
        return sel;
    }
    function findMatchingVariant() {
        const sel = getSelection();
        const candidates = variants.filter(v =>
        Object.keys(sel).every(k => !sel[k] || v[k] === sel[k])
        );
        return candidates.find(v => v.available) || candidates[0] || variants[0] || null;
    }
    function syncVariantAndPrice() {
        const variant = findMatchingVariant();
        const variantSelect = document.getElementById('qa-variant');
        if (variantSelect && variant) variantSelect.value = String(variant.id);
        if (typeof renderPriceForVariant === 'function') renderPriceForVariant(variant, product);
    }

    // --- build COLOR ---
    if (colorOpt) {
        const fs = document.createElement('fieldset');
        fs.className = 'qa-option qa-color';
        const legend = document.createElement('legend');
        legend.textContent = colorOpt.name;
        fs.appendChild(legend);

        if (colorOpt.values.length <= 3) {
        const seg = document.createElement('div');
        seg.className = 'qa-segmented';
        seg.dataset.role = 'color-radios';

        colorOpt.values.forEach((val, idx) => {
            const id = `qa-color-${slug(val)}`;
            const input = document.createElement('input');
            input.type = 'radio';
            input.className = 'sr-only';
            input.name = 'qa-color';
            input.id = id;
            input.value = val;

            const available = anyAvailable({[`option${colorOpt.index}`]: val});
            if (!available) input.disabled = true;

            const label = document.createElement('label');
            label.className = 'seg-btn';
            label.htmlFor = id;
            label.textContent = val;
            label.style.setProperty('--swatch', colorToHex(val));
            if (!available) label.dataset.soldout = 'true';

            if (idx === 0 && available) input.checked = true;

            seg.appendChild(input);
            seg.appendChild(label);
        });

        fs.appendChild(seg);
        } else {
        const wrap = document.createElement('div');
        wrap.className = 'qa-select-wrap';
        wrap.dataset.role = 'color-select';

        const select = document.createElement('select');
        select.id = 'qa-color';
        select.setAttribute('aria-label', 'Color');

        const ph = document.createElement('option');
        ph.value = '';
        ph.textContent = 'Choose a color';
        select.appendChild(ph);

        colorOpt.values.forEach(val => {
            const opt = document.createElement('option');
            opt.value = val;
            opt.textContent = val;
            if (!anyAvailable({[`option${colorOpt.index}`]: val})) opt.disabled = true;
            select.appendChild(opt);
        });

        wrap.appendChild(select);
        fs.appendChild(wrap);
        }

        optWrap.appendChild(fs);
    }

    // --- build SIZE (styled select) ---
    if (sizeOpt) {
        const fs = document.createElement('fieldset');
        fs.className = 'qa-option qa-size';

        const legend = document.createElement('legend');
        legend.textContent = sizeOpt.name;
        fs.appendChild(legend);

        const wrap = document.createElement('div');
        wrap.className = 'qa-select-wrap';
        wrap.dataset.role = 'size-select';

        const select = document.createElement('select');
        select.id = 'qa-size';
        select.setAttribute('aria-label', 'Size');

        const ph = document.createElement('option');
        ph.value = '';
        ph.textContent = 'Choose your size';
        select.appendChild(ph);

        sizeOpt.values.forEach(val => {
        const opt = document.createElement('option');
        opt.value = val;
        opt.textContent = val;
        if (!anyAvailable({[`option${sizeOpt.index}`]: val})) opt.disabled = true;
        select.appendChild(opt);
        });

        wrap.appendChild(select);
        fs.appendChild(wrap);
        optWrap.appendChild(fs);
    }

    // --- listeners + defaults ---
    if (colorOpt) {
        if (colorOpt.values.length <= 3) {
        optWrap.querySelectorAll('input[name="qa-color"]').forEach(i => i.addEventListener('change', syncVariantAndPrice));
        } else {
        optWrap.querySelector('#qa-color')?.addEventListener('change', syncVariantAndPrice);
        // set default to first enabled
        const firstEnabled = Array.from(optWrap.querySelector('#qa-color')?.options || [])
            .find(o => o.value && !o.disabled);
        if (firstEnabled) optWrap.querySelector('#qa-color').value = firstEnabled.value;
        }
    }
    if (sizeOpt) {
        const sel = optWrap.querySelector('#qa-size');
        if (sel) {
        sel.addEventListener('change', syncVariantAndPrice);
        const firstEnabled = Array.from(sel.options).find(o => o.value && !o.disabled);
        if (firstEnabled) sel.value = firstEnabled.value;
        }
    }

    syncVariantAndPrice(); // initialize price + hidden select
    }

  // close actions (backdrop, button, Esc)
  modal.addEventListener('click', function(e) {
    if (e.target.closest('[data-close-modal]')) closeModal();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
  });

  // ===== Plus icon click (event delegation) =====
  document.addEventListener('click', function(e) {
    const plusIcon = e.target.closest('.plus-icon');
    if (!plusIcon) return;

    e.preventDefault();
    const productHandle = plusIcon.getAttribute('data-product-handle');
    if (!productHandle) return;

    fetch(`/products/${productHandle}.js`, { credentials: 'same-origin' })
      .then(res => {
        if (!res.ok) throw new Error('Product not found');
        return res.json();
      })
      .then(product => {
        populateModal(product);
      })
      .catch(err => {
        console.error('Error loading product:', err);
      });
  });
})();
</script>
{% schema %}
{
    "name": "Tisso Vision Collection",
    "tag": "section",
    "class": "section",
    "disabled_on": {
        "groups": ["header", "footer"]
    },
    "settings": [
         {
            "type": "text",
            "id": "heading",
            "label": "Heading"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "min": 2,
            "max": 25,
            "step": 1,
            "default": 6,
            "label": "Product to Show"
        },     
    ],
    "blocks": [
        {
            "type": "product",
            "name": "Product",
            "settings": [
                {
                    "type": "product",
                    "id": "product",
                    "label": "Product"
                },
                {
                    "type": "text",
                    "id": "coordinate_top",
                    "label": "Top",
                    "info": "Enter the coordinates for this product from top (e.g., 10)"
                },
                {
                    "type": "text",
                    "id": "coordinate_left",
                    "label": "Left",
                    "info": "Enter the coordinates for this product from top (e.g., 10)"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Tisso Vision Collection",
            "category": "EcomExperts",
        }   
    ]
}
{%- endschema -%}