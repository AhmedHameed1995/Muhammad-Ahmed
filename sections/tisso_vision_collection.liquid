{%- if section.settings.collection.products.size > 0 -%}
    <div class="product_grid_wrapper">
        <div class="page-width container">
            <h2>{{section.settings.heading}}</h2>
        </div>
        <div class="page-width container">
            {%- for block in section.blocks -%}
                {%- assign product = all_products[block.settings.product] -%}
                {%- if product != blank -%}
                    <div class="tissio_products" 
                        data-coordinates="{{ block.settings.coordinates | escape }}">
                        <div class="product_image">
                            {%- if product.featured_media -%}
                                <img 
                                    src="{{ product.featured_media | image_url: width: 360, height: 360 }}" 
                                    alt="{{ product.featured_media.alt | escape }}"
                                    width="360" 
                                    height="360"
                                    loading="lazy"
                                >
                            {%- endif -%}
                            <span class="plus-icon" data-product-handle="{{ product.handle }}">+</span>
                        </div>
                    </div>
                {%- endif -%}
            {%- endfor -%}

        </div>
    </div>
{%- else -%}

{%- endif -%}


<style>
.product_grid_wrapper {
    margin-top:20px;
}
.product_grid_wrapper > .container {
    display: flex;
    gap: 10px 15px;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: flex-start;
}
.product_grid_wrapper > .container > * {
    flex: 0 0 100%;
    max-width: 32%;
}
.product_grid_wrapper > .container .product_image {
    overflow:hidden;
    display: inline-flex;
}
.product_grid_wrapper > .container .tissio_products:hover {
   cursor:pointer;
}

.product_grid_wrapper > .container .product_image img {
    max-width: 100%;
    height: 325px;
    object-fit:cover;
}
.product_grid_wrapper > .container .product_text a {
    text-decoration:none;
    color:currentColor;
}
.product_grid_wrapper > .container .product_text a:hover {
    text-decoration:underline;
}
.plus-icon {
    position: absolute;
    z-index: 5;
    background: #fff;
    font-size: 30px;
    width: 30px;
    height: 30px;
    line-height: 30px;
    text-align: center;
    color: #000;
    border-radius: 50%;
}
</style>
<script>
     document.addEventListener('click', function(e) {
            // Check if clicked element is plus icon or its child
            const plusIcon = e.target.closest('.plus-icon');
            if (plusIcon) {
                e.preventDefault();
                const productHandle = plusIcon.getAttribute('data-product-handle');
                console.log(productHandle);
            }
    });
</script>
{% schema %}
{
    "name": "Tisso Vision Collection",
    "tag": "section",
    "class": "section",
    "disabled_on": {
        "groups": ["header", "footer"]
    },
    "settings": [
         {
            "type": "text",
            "id": "heading",
            "label": "Heading"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "min": 2,
            "max": 25,
            "step": 1,
            "default": 6,
            "label": "Product to Show"
        },     
    ],
    "blocks": [
        {
            "type": "product",
            "name": "Product",
            "settings": [
                {
                    "type": "product",
                    "id": "product",
                    "label": "Product"
                },
                {
                    "type": "text",
                    "id": "coordinate_top",
                    "label": "Top",
                    "info": "Enter the coordinates for this product from top (e.g., 10)"
                },
                {
                    "type": "text",
                    "id": "coordinate_left",
                    "label": "Left",
                    "info": "Enter the coordinates for this product from top (e.g., 10)"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Tisso Vision Collection",
            "category": "EcomExperts",
        }   
    ]
}
{%- endschema -%}