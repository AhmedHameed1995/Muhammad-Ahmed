<div class="product_grid_wrapper">
    <div class="page-width container">
        <h2>{{section.settings.heading}}</h2>
    </div>
    <div class="page-width container">
        {%- for block in section.blocks -%}
            {%- assign product = all_products[block.settings.product] -%}
            {%- if product != blank -%}
                <div class="tissio_products" 
                    data-coordinates="{{ block.settings.coordinates | escape }}">
                    <div class="product_image">
                        {%- if product.featured_media -%}
                            <img 
                                src="{{ product.featured_media | image_url: width: 360, height: 360 }}" 
                                alt="{{ product.featured_media.alt | escape }}"
                                width="360" 
                                height="360"
                                loading="lazy"
                            >
                        {%- endif -%}
                        <span class="plus-icon" data-product-handle="{{ product.handle }}" style="top:{{ block.settings.coordinate_top | escape}}px; left:{{ block.settings.coordinate_left | escape }}px;">+</span>
                    </div>
                </div>
            {%- endif -%}
        {%- endfor -%}
        <!-- ===== Quick Add Modal (HTML) ===== -->
        <div id="quick-add-modal" class="qa-modal" aria-hidden="true">
        <div class="qa-backdrop" data-close-modal></div>
        <div class="qa-dialog" role="dialog" aria-modal="true" aria-labelledby="qa-modal-title">
            <button class="qa-close" type="button" aria-label="Close" data-close-modal>&times;</button>
            <div class="qa-body">
            <div class="qa-media">
                <img id="qa-image" alt="" />
            </div>
            <div class="qa-info">
                <h3 id="qa-modal-title"></h3>
                <div class="qa-price" id="qa-price"></div>
                <label class="qa-variant-wrap">
                <span>Variant</span>
                <select id="qa-variant"></select>
                </label>
                <div class="qa-actions">
                <a id="qa-view-link" class="qa-view-link" href="#">View product</a>
                </div>
            </div>
            </div>
        </div>
        </div>

    </div>
</div>


<style>
.product_grid_wrapper {
    margin-top:20px;
}
.product_grid_wrapper > .container {
    display: flex;
    gap: 10px 15px;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: flex-start;
}
.product_grid_wrapper > .container > * {
    flex: 0 0 100%;
    max-width: 32%;
}
.product_grid_wrapper > .container .product_image {
    overflow:hidden;
    display: inline-flex;
    position:relative;
}
.product_grid_wrapper > .container .tissio_products:hover {
   cursor:pointer;
}

.product_grid_wrapper > .container .product_image img {
    max-width: 100%;
    height: 325px;
    object-fit:cover;
}
.product_grid_wrapper > .container .product_text a {
    text-decoration:none;
    color:currentColor;
}
.product_grid_wrapper > .container .product_text a:hover {
    text-decoration:underline;
}
.plus-icon {
    position: absolute;
    z-index: 5;
    background: #fff;
    font-size: 25px;
    width: 25px;
    height: 25px;
    line-height: 25px;
    text-align: center;
    color: #000;
    border-radius: 50%;
}

.qa-modal { position: fixed; inset: 0; display: none; z-index: 9999; }
.qa-modal.is-open { display: block; }
.qa-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,.5); }
.qa-dialog {
  position: relative; max-width: 900px; margin: 5vh auto; background: #fff;
  border-radius: 16px; overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,.2);
}
.qa-close {
  position: absolute; right: 10px; top: 10px; background: #fff; border: 1px solid #eee;
  width: 36px; height: 36px; border-radius: 999px; cursor: pointer; font-size: 20px; line-height: 1;
}
.qa-body { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; padding: 20px; }
.qa-media img { width: 100%; height: 420px; object-fit: cover; border-radius: 12px; }
.qa-info h3 { margin: 0 0 8px; font-size: 20px; }
.qa-price { font-weight: 700; margin-bottom: 12px; }
.qa-price .compare { text-decoration: line-through; opacity: .6; margin-left: 8px; font-weight: 400; }
.qa-variant-wrap { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
.qa-variant-wrap select { padding: 10px; border: 1px solid #ddd; border-radius: 8px; }
.qa-actions { display: flex; gap: 10px; align-items: center; }
.qa-view-link { display: inline-block; padding: 10px 14px; border-radius: 8px; border: 1px solid #111; text-decoration: none; color: #111; font-weight: 600; }
@media (max-width: 768px) {
  .qa-body { grid-template-columns: 1fr; }
  .qa-media img { height: 300px; }
}
</style>
<script>
     document.addEventListener('click', function(e) {
            // Check if clicked element is plus icon or its child
            const plusIcon = e.target.closest('.plus-icon');
            if (plusIcon) {
                e.preventDefault();
                const productHandle = plusIcon.getAttribute('data-product-handle');
                console.log(productHandle);
                fetch(`/products/${productHandle}.js`)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Product not found');
                        }
                        return response.json();
                        //console.log(response.json());

                    })
                    .then(product => {
                        // Format price
                        console.log(product);
                    })
                    .catch(error => {
                        console.error('Error loading product:', error);
                    });
            }
    });
</script>
{% schema %}
{
    "name": "Tisso Vision Collection",
    "tag": "section",
    "class": "section",
    "disabled_on": {
        "groups": ["header", "footer"]
    },
    "settings": [
         {
            "type": "text",
            "id": "heading",
            "label": "Heading"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "min": 2,
            "max": 25,
            "step": 1,
            "default": 6,
            "label": "Product to Show"
        },     
    ],
    "blocks": [
        {
            "type": "product",
            "name": "Product",
            "settings": [
                {
                    "type": "product",
                    "id": "product",
                    "label": "Product"
                },
                {
                    "type": "text",
                    "id": "coordinate_top",
                    "label": "Top",
                    "info": "Enter the coordinates for this product from top (e.g., 10)"
                },
                {
                    "type": "text",
                    "id": "coordinate_left",
                    "label": "Left",
                    "info": "Enter the coordinates for this product from top (e.g., 10)"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Tisso Vision Collection",
            "category": "EcomExperts",
        }   
    ]
}
{%- endschema -%}