<div class="testing-banner">
    <div class="hero_top">
        {{ section.settings.hero_bottom }}
    </div>
    <div class="hero_bottom">
        {{ section.settings.hero_bottom }}
    </div>
</div>

<style>
.hero_bottom {
    background:#F5F5F5;
    font-size:18px;
    text-align:center;
}
</style>

{%- schema -%}
    {
        "name": "Banner Section",
        "class": "banner-homepage",
        "settings": [
            {
                "type": "header",
                "content": "== Top Bar"
            },
            {
                "type": "text",
                "id": "logo",
                "label": "Logo Text",
            },
            {
                "type": "text",
                "id": "ideal_gift_text",
                "label": "Ideal Gift Text",
            },
            {
                "type": "text",
                "id": "choose_gift",
                "label": "Choose Gift",
            },
            {
                "type": "header",
                "content": "== Design Options"
            },
            {
                "type": "image_picker",
                "id": "image",
                "label": "Banner Image",
                "info": "Image Dimension should be : "
            },
            {
                "type": "header",
                "content": "== Banner Text"
            },
            {
                "type": "text",
                "id": "hero_heading",
                "label": "Hero Heading",
            },
            {
                "type": "text",
                "id": "hero_text",
                "label": "Hero Text",
            },
            {
                "type": "text",
                "id": "hero_btn",
                "label": "Hero Button",
            },
            {
                "type": "text",
                "id": "hero_bottom",
                "label": "Hero Bottom Text",
            },
        ],
        "presets": [
            {
                "name": "Banner Section",
                "category": "EcomExperts",
            }
        ]
    }    	
{%- endschema -%}
